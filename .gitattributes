# Auto-detect text files and normalize line endings
* text=auto eol=lf

# Shell scripts — always LF, even on Windows checkout
*.sh text eol=lf

# Batch files — always CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary

# Lock files — exact as committed
pnpm-lock.yaml -diff linguist-generated
Cargo.lock -diff linguist-generated

# SQL migrations — LF for cross-platform consistency
*.sql text eol=lf
