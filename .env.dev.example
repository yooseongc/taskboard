# =============================================================================
# Taskboard — Development environment template
#
# Usage:
#   cp .env.dev.example .env.dev
#   docker compose -f docker-compose.dev.yml --env-file .env.dev up -d --build
#
# The in-repo Keycloak (localhost:8180) and GLAuth LDAP (localhost:3893) are
# started by the dev compose. Do not use these values in production.
# =============================================================================

# --- Postgres (dev) ---
DATABASE_URL=postgres://taskboard:taskboard@postgres:5432/taskboard

# --- Deployment mode ---
# `sso` (default) uses the in-repo Keycloak. Set to `personal` for a
# single-user standalone sandbox that skips Keycloak/LDAP entirely.
TASKBOARD_MODE=sso

# --- Backend: Keycloak (in-repo dev realm) ---
KEYCLOAK_ISSUER=http://keycloak:8080/realms/taskboard
KEYCLOAK_AUDIENCE=taskboard-backend

# --- Backend: HTTP ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
BACKEND_BIND_ADDR=0.0.0.0:8080
LOG_LEVEL=info
LOG_FORMAT=json

# --- Backend: Admin bootstrap ---
# Comma-separated emails that receive SystemAdmin on first sign-in.
SYSTEM_ADMIN_EMAILS=alice@example.com,admin@example.com

# --- Backend: OIDC groups -> departments sync ---
OIDC_DEPT_CLAIM=groups
OIDC_DEPT_SYNC_ENABLED=true

# --- Backend: dev-auth (HS256 shortcut, compiled into dev image only) ---
TASKBOARD_DEV_AUTH=1
TASKBOARD_DEV_AUTH_HMAC_KEY=dev-hmac-key-at-least-32-bytes-long!!

# --- Frontend (Vite dev server, port 5173) ---
VITE_BACKEND_URL=http://localhost:8080
VITE_KEYCLOAK_URL=http://localhost:8180
VITE_KEYCLOAK_REALM=taskboard
VITE_KEYCLOAK_CLIENT_ID=taskboard-frontend

# --- Frontend: dev-auth login helper ---
VITE_DEV_AUTH_ENABLED=1
VITE_DEV_AUTH_LOGIN_URL=http://localhost:8080/api/dev/login
