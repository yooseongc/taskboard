# =============================================================================
# Taskboard Environment Variables (S-029: 19 keys)
# =============================================================================

# --- Backend Core (11 keys) ---
DATABASE_URL=postgres://taskboard:taskboard@postgres:5432/taskboard
KEYCLOAK_ISSUER=http://keycloak:8080/realms/taskboard
# KEYCLOAK_JWKS_URL=                    # Optional: derived from KEYCLOAK_ISSUER
KEYCLOAK_AUDIENCE=taskboard-backend
CORS_ALLOWED_ORIGINS=http://localhost:5173
BACKEND_BIND_ADDR=0.0.0.0:8080
LOG_LEVEL=info
LOG_FORMAT=json
JWKS_CACHE_TTL_SECS=600
JWKS_GRACE_TTL_SECS=600
SEED_ON_START=false

# System admin identification (comma-separated emails)
SYSTEM_ADMIN_EMAILS=admin@example.com

# --- Backend Dev-Auth (2 keys, uncomment for dev) ---
# TASKBOARD_DEV_AUTH=1
# TASKBOARD_DEV_AUTH_HMAC_KEY=change-me-to-a-secure-random-string-at-least-32-bytes

# --- Frontend Core (4 keys) ---
VITE_BACKEND_URL=http://localhost:8080
VITE_KEYCLOAK_URL=http://localhost:8180
VITE_KEYCLOAK_REALM=taskboard
VITE_KEYCLOAK_CLIENT_ID=taskboard-frontend

# --- Frontend Dev-Auth (2 keys, uncomment for dev) ---
# VITE_DEV_AUTH_ENABLED=1
# VITE_DEV_AUTH_LOGIN_URL=http://localhost:8080/api/dev/login
