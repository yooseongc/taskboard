# =============================================================================
# Taskboard — Production environment template
#
# Usage:
#   cp .env.example .env
#   docker compose up -d --build
#
# For local development, use .env.dev.example instead.
# =============================================================================

# --- Postgres ---
POSTGRES_USER=taskboard
POSTGRES_PASSWORD=replace-with-a-strong-secret

# --- Backend: Keycloak / OIDC (external) ---
# Issuer URL exposed by your production Keycloak. Must be reachable from the backend container.
KEYCLOAK_ISSUER=https://auth.example.com/realms/taskboard
KEYCLOAK_AUDIENCE=taskboard-backend
# Optional: override JWKS URL if it cannot be derived from the issuer.
# KEYCLOAK_JWKS_URL=

# --- Backend: HTTP ---
# CORS must be an explicit list — wildcards are rejected by the backend.
CORS_ALLOWED_ORIGINS=https://taskboard.example.com
BACKEND_BIND_ADDR=0.0.0.0:8080
BACKEND_PORT=8080
LOG_LEVEL=warn
LOG_FORMAT=json

# --- Backend: JWKS cache ---
JWKS_CACHE_TTL_SECS=600
JWKS_GRACE_TTL_SECS=600

# --- Backend: Admin bootstrap ---
# Comma-separated emails that receive SystemAdmin on first sign-in.
SYSTEM_ADMIN_EMAILS=admin@example.com

# --- Backend: OIDC groups -> departments sync ---
# Claim name that contains the user's AD groups (via Keycloak). Must match departments.slug exactly.
OIDC_DEPT_CLAIM=groups
OIDC_DEPT_SYNC_ENABLED=true

# --- Frontend: build-time ---
# Browser-facing Keycloak URL (public), baked into the frontend bundle at build time.
VITE_KEYCLOAK_URL=https://auth.example.com
VITE_KEYCLOAK_REALM=taskboard
VITE_KEYCLOAK_CLIENT_ID=taskboard-frontend
FRONTEND_PORT=80
